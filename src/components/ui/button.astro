---
interface Props
  extends astroHTML.JSX.ButtonHTMLAttributes,
    astroHTML.JSX.AnchorHTMLAttributes {
  variant?: 'default' | 'outline';
  href?: string;
}

const {
  class: className = '',
  variant = 'default',
  type = 'button',
  href,
  ...props
} = Astro.props;

const baseClass =
  'inline-flex w-full items-center justify-center whitespace-nowrap rounded-md px-4 py-3 text-sm font-medium transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/50 disabled:pointer-events-none disabled:opacity-50 focus-visible:bg-accent';

const variantClass =
  variant === 'outline'
    ? 'border border-black/15 bg-white text-body hover:bg-accent'
    : 'border border-transparent bg-body text-white hover:bg-accent';
---

{href ? (
  <a href={href} class={`${baseClass} ${variantClass} ${className}`.trim()} {...props}>
    <slot />
  </a>
) : (
  <button type={type} class={`${baseClass} ${variantClass} ${className}`.trim()} {...props}>
    <slot />
  </button>
)}
